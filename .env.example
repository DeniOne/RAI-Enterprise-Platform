# Database (PostgreSQL + PostGIS)
DATABASE_URL="postgresql://rai_admin:secret@localhost:5432/rai_platform?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO (S3 Storage)
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ROOT_USER="rai_admin"
MINIO_ROOT_PASSWORD="rai_secret_password"
MINIO_BUCKET_NAME="rai-assets"
MINIO_USE_SSL="false"

# Audit WORM / Notarization
AUDIT_WORM_PROVIDER="filesystem"
AUDIT_WORM_ALLOW_FILESYSTEM_IN_PRODUCTION="false"
WORM_S3_BUCKET="rai-audit-worm"
WORM_S3_PREFIX="audit-worm"
WORM_S3_REGION="us-east-1"
WORM_S3_OBJECT_LOCK_REQUIRED="true"
WORM_S3_AUTO_CREATE_BUCKET="true"
WORM_S3_AUTO_CONFIGURE_DEFAULT_RETENTION="true"
WORM_S3_RETENTION_MODE="COMPLIANCE"
WORM_S3_RETENTION_YEARS=7

# Business Core API (MatrixGin Space)
CORE_API_URL="http://localhost:3001"
CORE_API_KEY="your-api-key"
LOOKUP_PROVIDER_PRIMARY="DADATA"
DADATA_API_KEY=""
DADATA_SECRET_KEY=""

# JWT Auth
JWT_SECRET="change-this-to-a-secure-key-in-production"
RAI_HUMAN_CONFIRMATION_ENABLED="true"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# Monitoring
SENTRY_DSN=""
